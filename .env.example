# Copy to .env (gitignored) and fill in. NEVER commit real values.

# DagsHub-hosted MLflow tracking server
MLFLOW_TRACKING_URI=https://dagshub.com/mohanemg07-web/ML-Pipeline-with-CI-CD-Drift-Monitoring.mlflow
MLFLOW_TRACKING_USERNAME=mohanemg07-web
MLFLOW_TRACKING_PASSWORD=<dagshub-token>

# Render
RENDER_DEPLOY_HOOK_URL=<render-deploy-hook-url>
SERVING_BASE_URL=<https://your-service.onrender.com>

# Serving: shadow-mode challenger traffic percentage (0 disables)
CHALLENGER_TRAFFIC_PCT=0
