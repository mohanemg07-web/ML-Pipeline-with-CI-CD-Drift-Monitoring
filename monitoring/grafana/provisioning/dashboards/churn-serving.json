{
  "uid": "churn-serving",
  "title": "Churn Serving — Live (Render)",
  "tags": ["churn", "serving", "render"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Live model version",
      "description": "From churn_model_info — must agree with /health. Registry champion shows the version number (e.g. 2); a bundled fallback shows a file-sha256 hash.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "churn_model_info",
          "legendFormat": "v{{model_version}} · {{model_source}}",
          "instant": true
        }
      ],
      "options": {
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Serving endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"churn-serving-live\"}",
          "legendFormat": "up",
          "instant": true
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Predicted churn share (15m)",
      "description": "Fraction of served predictions with probability > 0.5, from the probability histogram buckets.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (sum(rate(churn_prediction_probability_bucket{le=\"0.5\"}[15m])) / sum(rate(churn_prediction_probability_count[15m])))",
          "legendFormat": "churn share",
          "instant": true
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "5xx error rate (5m)",
      "description": "Server faults only — 4xx client errors are tracked separately below.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(churn_http_requests_total{code=~\"5..\"}[5m])) or vector(0)) / sum(rate(churn_http_requests_total[5m]))",
          "legendFormat": "5xx share",
          "instant": true
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Prediction request rate by endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(churn_predictions_total[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Scoring latency P50 / P95 / P99 (in-process)",
      "description": "histogram_quantile over churn_predict_latency_seconds buckets. This is model scoring time inside the process — the Phase 2 client-observed P99 (696 ms) additionally includes network RTT.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(churn_predict_latency_seconds_bucket[5m])))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(churn_predict_latency_seconds_bucket[5m])))",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(churn_predict_latency_seconds_bucket[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error rate: 4xx and 5xx share of matched-route requests",
      "description": "5xx = server faults (alert at >5%/5m). 4xx = client errors, e.g. invalid payloads (alert at >30%/2m). Scanner traffic on unmatched routes is excluded.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(churn_http_requests_total{code=~\"5..\", endpoint!=\"unmatched\"}[5m])) or vector(0)) / sum(rate(churn_http_requests_total{endpoint!=\"unmatched\"}[5m]))",
          "legendFormat": "5xx share"
        },
        {
          "refId": "B",
          "expr": "(sum(rate(churn_http_requests_total{code=~\"4..\", endpoint!=\"unmatched\"}[5m])) or vector(0)) / sum(rate(churn_http_requests_total{endpoint!=\"unmatched\"}[5m]))",
          "legendFormat": "4xx share"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx share" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx share" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 8,
      "type": "heatmap",
      "title": "Served churn-probability distribution (drift signal)",
      "description": "churn_prediction_probability histogram over time. A shifting band = the served population is drifting.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (increase(churn_prediction_probability_bucket[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "none", "decimals": 1 },
        "color": { "mode": "scheme", "scheme": "Oranges", "steps": 32 },
        "cellGap": 1
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
